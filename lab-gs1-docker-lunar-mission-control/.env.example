# =============================================================================
# Lunar Mission Control - variáveis de ambiente da stack
#
# Uso:
#   cp .env.example .env
#
# IMPORTANTE (segurança): estes são valores SIMPLES para a atividade acadêmica.
# Em produção real, senhas NÃO devem ficar em arquivo versionável -> usar um
# gerenciador de segredos (Docker/Swarm secrets, AWS Secrets Manager/SSM, etc.).
# =============================================================================

# ---- Aplicação (Node.js) ----
APP_PORT=3000
APP_ENV=production
NODE_ENV=production
MISSION_NAME=Artemis FIAP Lunar Base

# Porta HTTP pública (a ÚNICA publicada para fora, via Nginx).
# Em EC2 use 80. Em Mac/local, se a porta 80 estiver ocupada, use 8080.
PUBLIC_HTTP_PORT=80

# ---- Banco de dados (MySQL) ----
MYSQL_DATABASE=lunar_mission
MYSQL_USER=lunar_user
MYSQL_PASSWORD=lunarpass
MYSQL_ROOT_PASSWORD=rootpass

# ---- Cache (Redis) ----
REDIS_HOST=redis
REDIS_PORT=6379
